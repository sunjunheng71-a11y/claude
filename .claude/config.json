{
  "name": "AI Learning Platform",
  "description": "大学生AI学习平台 - 二维码生成与系统维护",
  "version": "1.0.0",
  "created": "2026-03-24",
  "author": "大学生AI学习者",
  "autoMode": true,
  "permissions": {
    "bash": [
      "npm",
      "node",
      "git",
      "docker",
      "curl",
      "mkdir",
      "cp",
      "rm",
      "ps",
      "pgrep",
      "pkill",
      "tail",
      "head",
      "grep",
      "find",
      "du",
      "df"
    ],
    "file": [
      "read",
      "write",
      "edit",
      "delete",
      "create"
    ],
    "network": [
      "api",
      "web",
      "localhost",
      "github"
    ],
    "tools": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent"
    ]
  },
  "hooks": {
    "pre-project": "bash scripts/setup-env.sh",
    "pre-deploy": "bash scripts/setup-env.sh && bash scripts/stop-all.sh",
    "deploy": "bash scripts/deploy.sh",
    "post-deploy": "bash scripts/monitor.sh",
    "pre-commit": "cd frontend && npm run build",
    "post-commit": "bash scripts/deploy.sh"
  },
  "environment": {
    "NODE_ENV": "development",
    "PORT": "3001",
    "CLAUDE_AUTO_MODE": "true",
    "PROJECT_ROOT": "D:\\claude"
  },
  "features": {
    "autoFix": true,
    "autoTest": true,
    "autoDeploy": true,
    "autoMonitor": true,
    "qrGeneration": true,
    "systemMonitoring": true,
    "githubIntegration": true,
    "autoSync": true,
    "codeVersioning": true
  },
  "dependencies": {
    "required": ["node", "npm", "git"],
    "optional": ["docker", "python", "github-cli"],
    "backend": ["express", "cors", "qr-image"],
    "frontend": ["react", "vite"],
    "github": ["git", "ssh-keygen", "curl"]
  }
}